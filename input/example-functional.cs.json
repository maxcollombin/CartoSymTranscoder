{
  "metadata": {
    "title": "Exemple de style fonctionnel",
    "abstract": "Exemple minimal pour CartoSym JSON compatible Pydantic"
  },
  "stylingRules": [
    {
      "name": "Landuse",
      "selector": {
        "op": "=",
        "args": [
          { "property": "Landuse" },
          "park"
        ]
      },
      "symbolizer": {
        "visibility": true,
        "opacity": 1.0,
        "zOrder": 1,
        "fill": {
          "color": "green",
          "opacity": 0.5
        },
        "stroke": {
          "color": "darkGreen",
          "opacity": 1.0,
          "width": { "value": 2.0, "unit": "px" }
        }
      },
      "nestedRules": [
        {
          "name": "Parking",
          "selector": {
            "op": "=",
            "args": [
              { "property": "FunctionCode" },
              "parking"
            ]
          },
          "symbolizer": {
            "fill": { "color": "gray" },
            "stroke": { "color": "darkGray" }
          }
        }
      ]
    }
  ]
}
