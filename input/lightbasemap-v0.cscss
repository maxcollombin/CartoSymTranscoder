         color: (class IN [ { b = 15 }, {  } ]) ? { 186, 210, 172 } : (class IN [ {  }, {  } ]) ? { 205, 232, 244 } : (class = {  }) ? { 204, 229, 245 } : (class = {  }) ? { 240, 218, 188 } : { 215, 224, 209 }
      };
      visibility: true;
   }

   [viz.sd <= 550000][subclass IN [ 'wood', 'scrub', 'recreation_ground', 'park', 'golf_course', 'allotments', 'plant_nursery', 'forest' ]]
   {
      stroke:
      {
         color: { 186, 199, 172 };
         opacity: interpolate('exponential', 29.0584853377 - log(2, viz.sd), 12, 0, 14, 1, 15, 1, 15.5, 0, 1.5) * 1.0;
         width: (interpolate('exponential', 29.0584853377 - log(2, viz.sd), 6, 0, 11, 0.25, 16, 0.75, 1.5)) > 0.75 ? Meters { 1.79 } : interpolate('exponential', 29.0584853377 - log(2, viz.sd), 6, 0, 11, 0.25, 16, 0.75, 1.5)
      };
      visibility: true;
   }

   [viz.sd <= 68000][subclass IN [ 'orchard', 'swamp', 'vineyard' ]]
