construct
{
   zOrder: 13;
   visibility: false;

   [viz.sd <= 34000][class = 'lock']
   {
      stroke:
      {
         color: { 1, 1, 1 };
         opacity: (viz.sd < 17000) ? 0 : 1 * 'hsl(220, 10%, 67%)';
         width: (viz.sd < 2100) ? 1 : 4
      };
      visibility: true;
   }

   [viz.sd <= 68000][class <> 'lock']
   {
      stroke:
      {
         color: interpolate('exponential', 29.0584853377 - log(2, viz.sd), 13, (class = {  }) ? { 1, 1, 1 } : { 1, 1, 1 }, 17, (class = {  }) ? { 1, 1, 1 } : (class = { b = 218 }) ? { 1, 1, 1 } : { 1, 1, 1 }, 1)
      };
      fill:
      {
         opacity: interpolate('exponential', 29.0584853377 - log(2, viz.sd), 12, 0, 13, (class = 'dam') ? 1 : 0, 14, (class = 'dam') ? 1 : 0, 15, 1, 15.5, 0, 1) * interpolate('exponential', 29.0584853377 - log(2, viz.sd), 13, (class = 'weir') ? 'hsl(220, 10%, 82%)' : 'hsl(220, 10%, 86%)', 17, (class = 'weir') ? 'hsl(220, 10%, 75%)' : (class = 'dam') ? 'hsl(220, 10%, 82%)' : 'hsl(220, 10%, 86%)', 1);
         color: interpolate('exponential', 29.0584853377 - log(2, viz.sd), 13, (class = {  }) ? { 1, 1, 1 } : { 1, 1, 1 }, 17, (class = {  }) ? { 1, 1, 1 } : (class = { b = 218 }) ? { 1, 1, 1 } : { 1, 1, 1 }, 1)
      };
      visibility: true;
   }
}

aeroway
{
   zOrder: 14;
   visibility: false;

   [viz.sd <= 270000][class IN [ 'runway', 'taxiway', 'apron', 'runway_grass' ]]["$type" = 'Polygon']
   {
      stroke:
      {
         color: (class = {  }) ? { 224, 234, 221 } : { 255, 255, 255 }
      };
      fill:
      {
         opacity: interpolate('linear', 29.0584853377 - log(2, viz.sd), 15, 1, 15.5, 0) * (class = 'runway_grass') ? 1.0 : 1.0;
         color: (class = {  }) ? { 224, 234, 221 } : { 255, 255, 255 }
      };
      visibility: true;
   }
}

building_ln
{
   zOrder: 15;
   visibility: false;

   [viz.sd <= 68000][class IN [ 'horse_racing', 'ski_jump', 'toboggan', 'track', 'weir' ]]['geometry-type' = 'LineString']
   {
      stroke:
      {
         color: (class = {  }) ? { 20, 136, 205 } : { 130, 130, 130 };
         opacity: interpolate('linear', 29.0584853377 - log(2, viz.sd), 15, (class = 'weir') ? 0.2 : 1, 15.5, 0) * (class = 'weir') ? 1.0 : 1.0;
         width: (viz.sd < 2100) ? (viz.sd < 8500) ? 0 : 2 : 3
      };
      visibility: true;
   }
}

building
{
   zOrder: 16;
   visibility: false;

   [viz.sd <= 68000]
   {
      stroke:
      {
         color: (viz.sd < 4300) ? { 1, 1, 1 } : { 1, 1, 1 }
      };
      fill:
      {
         opacity: (viz.sd < 17000) ? 0 : 1 * (viz.sd < 4300) ? 'hsl(220, 10%, 82%)' : 'hsl(220, 10%, 75%)';
         color: (viz.sd < 4300) ? { 1, 1, 1 } : { 1, 1, 1 }
      };
      visibility: true;
   }

   [viz.sd <= 17000]
   {
      stroke:
      {
         color: { 1, 1, 1 };
         opacity: interpolate('linear', 29.0584853377 - log(2, viz.sd), 15, 0, 15.5, 0) * 'hsl(220, 10%, 67%)';
         width: (interpolate('linear', 29.0584853377 - log(2, viz.sd), 15, 0.2, 18, 1.2)) > 1.2 ? Meters { 0.72 } : interpolate('linear', 29.0584853377 - log(2, viz.sd), 15, 0.2, 18, 1.2)
      };
      visibility: true;
   }
}

