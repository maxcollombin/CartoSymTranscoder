place
{
   zOrder: 30;
   visibility: false;

   [viz.sd <= 140000][class NOT IN [ 'continent', 'country', 'state', 'city', 'town', 'village' ]]
   {
      label:
      {
         elements: [
            Image { image: { id: viz.sd > 140000 ? ((class IN [ 'hamlet', 'isolated_dwelling' ]) ? 'circle_dark_grey_4' : '') : (class IN [ 'hamlet', 'isolated_dwelling' ]) ? 'circle_dark_grey_6' : '' }, scaling: 1, hotSpot: { x: 0.5, y: 0.5 } },
            Text { text: "name:latin", font: { face: 'Frutiger Neue Condensed Medium', size: (interpolate('cubic-bezier', 29.0584853377 - log(2, viz.sd), 4, (class IN [ 'hamlet', 'isolated_dwelling' ]) ? (population <= 50) ? 6 : 4 : (population <= 5000) ? 8 : (population <= 2000) ? 6 : 4, 16, (class IN [ 'hamlet', 'isolated_dwelling' ]) ? (population <= 50) ? 20 : 18 : (population <= 5000) ? 22 : (population <= 2000) ? 20 : 18, 0.5)) * 0.75, outline: { size: interpolate('cubic-bezier', 29.0584853377 - log(2, viz.sd), 12, 1, 16, 2, 0), color: { 242, 242, 242 }, opacity: 1.0 }, color: { 64, 64, 64 } }, alignment: { horzAlign: center, vertAlign: middle }, position2D: { x: *interpolate('cubic-bezier', 29.0584853377 - log(2, viz.sd), 4, (class IN [ 'hamlet', 'isolated_dwelling' ]) ? (population <= 50) ? 6 : 4 : (population <= 5000) ? 8 : (population <= 2000) ? 6 : 4, 16, (class IN [ 'hamlet', 'isolated_dwelling' ]) ? (population <= 50) ? 20 : 18 : (population <= 5000) ? 22 : (population <= 2000) ? 20 : 18, 0.5), y: *interpolate('cubic-bezier', 29.0584853377 - log(2, viz.sd), 4, (class IN [ 'hamlet', 'isolated_dwelling' ]) ? (population <= 50) ? 6 : 4 : (population <= 5000) ? 8 : (population <= 2000) ? 6 : 4, 16, (class IN [ 'hamlet', 'isolated_dwelling' ]) ? (population <= 50) ? 20 : 18 : (population <= 5000) ? 22 : (population <= 2000) ? 20 : 18, 0.5) } }
         ];
