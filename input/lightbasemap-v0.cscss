hillshade
{
   zOrder: 1;
   visibility: false;

   [luminosity < 0]
   {
      stroke:
      {
         color: (luminosity = -15) ? { 200, 210, 213 } : (luminosity = -14) ? { 203, 213, 216 } : (luminosity = -13) ? { 207, 215, 218 } : (luminosity = -12) ? { 210, 218, 221 } : (luminosity = -11) ? { 213, 221, 224 } : (luminosity = -10) ? { 217, 224, 226 } : (luminosity = -9) ? { 220, 227, 229 } : (luminosity = -8) ? { 224, 230, 231 } : (luminosity = -7) ? { 227, 232, 234 } : (luminosity = -6) ? { 231, 235, 237 } : (luminosity = -5) ? { 234, 238, 239 } : (luminosity = -4) ? { 238, 241, 242 } : (luminosity = -3) ? { 241, 244, 245 } : (luminosity = -2) ? { 245, 247, 247 } : (luminosity = -1) ? { 248, 249, 250 } : { 252, 252, 252 }
      };
      fill:
      {
         opacity: (viz.sd < 2200000) ? 0.5 : 1 * (luminosity = -15) ? 1.0 : (luminosity = -14) ? 1.0 : (luminosity = -13) ? 1.0 : (luminosity = -12) ? 1.0 : (luminosity = -11) ? 1.0 : (luminosity = -10) ? 1.0 : (luminosity = -9) ? 1.0 : (luminosity = -8) ? 1.0 : (luminosity = -7) ? 1.0 : (luminosity = -6) ? 1.0 : (luminosity = -5) ? 1.0 : (luminosity = -4) ? 1.0 : (luminosity = -3) ? 1.0 : (luminosity = -2) ? 1.0 : (luminosity = -1) ? 1.0 : 1.0;
         color: (luminosity = -15) ? { 200, 210, 213 } : (luminosity = -14) ? { 203, 213, 216 } : (luminosity = -13) ? { 207, 215, 218 } : (luminosity = -12) ? { 210, 218, 221 } : (luminosity = -11) ? { 213, 221, 224 } : (luminosity = -10) ? { 217, 224, 226 } : (luminosity = -9) ? { 220, 227, 229 } : (luminosity = -8) ? { 224, 230, 231 } : (luminosity = -7) ? { 227, 232, 234 } : (luminosity = -6) ? { 231, 235, 237 } : (luminosity = -5) ? { 234, 238, 239 } : (luminosity = -4) ? { 238, 241, 242 } : (luminosity = -3) ? { 241, 244, 245 } : (luminosity = -2) ? { 245, 247, 247 } : (luminosity = -1) ? { 248, 249, 250 } : { 252, 252, 252 }
      };
      visibility: true;
   }

   [viz.sd <= 8700000][luminosity > 0][mask NOT IN [ 'rock', 'ice', 'scree' ]]
   {
      stroke:
      {
         color: { 255, 217, 5 }
      };
      fill:
      {
         opacity: interpolate('linear', 29.0584853377 - log(2, viz.sd), 9, 0.015, 11, 0.02) * 1.0;
         color: { 255, 217, 5 }
      };
      visibility: true;
   }
}

scree
{
   zOrder: 2;
   visibility: false;

   [viz.sd <= 4300]
   {
      fill:
      {
         opacity: 0.5
      };
      visibility: true;
   }

   [viz.sd <= 17000][viz.sd >= 4300]
   {
      fill:
      {
         opacity: 0.5
      };
      visibility: true;
   }

   [viz.sd <= 68000][viz.sd >= 17000]
   {
      fill:
      {
         opacity: 0.5
      };
      visibility: true;
   }

   [viz.sd <= 270000][viz.sd >= 68000]
   {
      fill:
      {
         opacity: 0.5
      };
      visibility: true;
   }
}

