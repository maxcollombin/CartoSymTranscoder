         color: { 240, 218, 188 }
      };
      visibility: true;
   }
}

landuse
{
   zOrder: 6;
   visibility: false;

   [class IN [ 'landfill', 'cemetery', 'quarry', 'zoo', 'pitch' ]]
   {
      stroke:
