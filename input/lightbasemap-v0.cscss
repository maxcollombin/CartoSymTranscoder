            Text { text: strupr("name:latin"), font: { face: 'Frutiger Neue Condensed Bold', size: (interpolate('cubic-bezier', 29.0584853377 - log(2, viz.sd), 1, 11, 4, 12, 16, 48, 0.5)) * 0.75, outline: { size: interpolate('cubic-bezier', 29.0584853377 - log(2, viz.sd), 12, 1, 16, 3, 0), color: { 242, 242, 242 }, opacity: 1.0 }, color: { 64, 64, 64 } }, alignment: { horzAlign: center, vertAlign: middle }, position2D: { x: *interpolate('cubic-bezier', 29.0584853377 - log(2, viz.sd), 1, 11, 4, 12, 16, 48, 0.5), y: *interpolate('cubic-bezier', 29.0584853377 - log(2, viz.sd), 1, 11, 4, 12, 16, 48, 0.5) } }
         ];
