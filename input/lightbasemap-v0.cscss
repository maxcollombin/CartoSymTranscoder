         opacity: (viz.sd < 17000) ? 0 : 1 * 1.0;
         color: { 255, 255, 255 }
      };
      visibility: true;
   }
}

waterway
{
   zOrder: 7;
   visibility: false;

   [viz.sd <= 140000][intermittent = 1]
   {
      stroke:
      {
