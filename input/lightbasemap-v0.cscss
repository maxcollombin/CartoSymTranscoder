         color: (class = {  }) ? { 224, 234, 221 } : (class IN [ {  }, {  } ]) ? { 240, 218, 188 } : (class IN [ { b = 206 }, {  } ]) ? { 215, 224, 209 } : (class = {  }) ? { 255, 255, 255 } : { 215, 224, 209 }
      };
      fill:
      {
         opacity: interpolate('linear', 29.0584853377 - log(2, viz.sd), 15, (class = 'pitch') ? 1 : 0.3, 15.5, 0) * (class = 'pitch') ? 1.0 : (class IN [ 'landfill', 'quarry' ]) ? 1.0 : (class IN [ 'cemetery', 'zoo' ]) ? 1.0 : (class = 'parking') ? 1.0 : 1.0;
         color: (class = {  }) ? { 224, 234, 221 } : (class IN [ {  }, {  } ]) ? { 240, 218, 188 } : (class IN [ { b = 206 }, {  } ]) ? { 215, 224, 209 } : (class = {  }) ? { 255, 255, 255 } : { 215, 224, 209 }
      };
      visibility: true;
   }

   [class IN [ 'cemetery', 'zoo', 'pitch' ]]
   {
      stroke:
      {
         color: (class = {  }) ? { 130, 130, 130 } : { 186, 199, 172 };
         opacity: (viz.sd < 17000) ? 0 : 1 * (class = 'pitch') ? 1.0 : 1.0;
         width: (interpolate('exponential', 29.0584853377 - log(2, viz.sd), 11, 0.25, 16, 0.75, 1.5)) > 0.75 ? Meters { 1.79 } : interpolate('exponential', 29.0584853377 - log(2, viz.sd), 11, 0.25, 16, 0.75, 1.5)
      };
      visibility: true;
   }

   [class IN [ 'parking' ]]
   {
