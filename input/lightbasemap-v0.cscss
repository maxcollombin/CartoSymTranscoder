      {
         color: { 130, 130, 130 };
         opacity: (viz.sd < 17000) ? 0 : 1 * 1.0;
         width: (interpolate('exponential', 29.0584853377 - log(2, viz.sd), 11, 0.25, 16, 0.75, 1.5)) > 0.75 ? Meters { 1.79 } : interpolate('exponential', 29.0584853377 - log(2, viz.sd), 11, 0.25, 16, 0.75, 1.5)
      };
      fill:
