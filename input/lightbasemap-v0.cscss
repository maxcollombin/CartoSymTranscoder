   [viz.sd <= 17000000][subclass IN [ 'allotments', 'forest', 'glacier', 'golf_course', 'loose_forest', 'park', 'plant_nursery', 'recreation_ground', 'scrub', 'woody_plant' ] OR ([ 'typeof', class ] = 'string') ? class = 'sand' : false]
   {
      stroke:
      {
         color: (class IN [ { b = 15 }, {  } ]) ? { 186, 210, 172 } : (class IN [ {  }, {  } ]) ? { 205, 232, 244 } : (class = {  }) ? { 204, 229, 245 } : (class = {  }) ? { 240, 218, 188 } : { 215, 224, 209 }
