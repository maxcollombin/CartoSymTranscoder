# EditorConfig — https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
indent_size = 4
max_line_length = 88

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{json,yaml,yml,toml}]
indent_size = 2

[*.{xml,sld}]
indent_size = 2

[Makefile]
indent_style = tab
